	},
	{
		id: 5,
		title: "Container Security Best Practices",
		readingTime: 6,
		date: "2024-01-30",
		image: "https://images.pexels.com/photos/60504/security-protection-anti-virus-software-60504.jpeg?auto=compress&cs=tinysrgb&w=200",
