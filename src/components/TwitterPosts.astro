		readingTime: 9,
		date: "2024-02-02",
		image: "https://images.pexels.com/photos/1181354/pexels-photo-1181354.jpeg?auto=compress&cs=tinysrgb&w=200",
		category: "SRE",
		excerpt: "",
		content: "",
		tags: [],
		author: "",
