---
	import '../styles/global.css'
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Diego Herrera Portfolio</title>
	</head>
	<body class="bg-slate-950 text-white antialiased">
		<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-slate-950/80 border-b border-navy-800/50">
			<nav class="container mx-auto px-6 py-4">
				<div class="flex items-center justify-between">
					<a href="/" class="text-2xl font-bold bg-gradient-to-r from-blue-400 to-navy-400 bg-clip-text text-transparent">
						Diego Herrera
					</a>
					<ul class="flex gap-8 text-sm">
						<li><a href="#home" class="hover:text-blue-400 transition-colors">Home</a></li>
						<li><a href="#news" class="hover:text-blue-400 transition-colors">Tech News</a></li>
					</ul>
				</div>
			</nav>
		</header>
		<main class="pt-16">
			<slot />
		</main>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
