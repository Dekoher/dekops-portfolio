---
interface BlogPost {
	id: number;
	title: string;
	excerpt: string;
	content: string;
	category: string;
	image: string;
	tags: string[];
	readingTime: number;
	date: string;
	author: string;
	isPopular?: boolean;
}

const recentPosts: BlogPost[] = [
	{
		id: 1,
		title: "Kubernetes Best Practices for Production Deployments",
		excerpt: "Learn the essential strategies for deploying and managing Kubernetes clusters in production environments with high availability and security.",
		content: "Kubernetes has become the standard for container orchestration. In this comprehensive guide, we explore best practices including resource management, security policies, monitoring, and scaling strategies.",
		category: "Working Tips",
		image: "https://images.pexels.com/photos/577585/pexels-photo-577585.jpeg?auto=compress&cs=tinysrgb&w=600",
		tags: ["#Kubernetes", "#DevOps", "#Infrastructure"],
		readingTime: 8,
		date: "2024-02-10",
		author: "Diego Herrera"
	},
	{
		id: 2,
		title: "Mastering CI/CD Pipelines with GitHub Actions",
		excerpt: "Discover how to build efficient continuous integration and deployment pipelines using GitHub Actions, reducing deployment times and improving reliability.",
		content: "GitHub Actions provides a powerful workflow automation platform. We cover setting up workflows, managing secrets, caching dependencies, and implementing complex deployment strategies.",
		category: "Working Tips",
		image: "https://images.pexels.com/photos/1181677/pexels-photo-1181677.jpeg?auto=compress&cs=tinysrgb&w=600",
		tags: ["#CI/CD", "#GitHub", "#Automation"],
		readingTime: 10,
		date: "2024-02-08",
		author: "Diego Herrera"
	}
];

